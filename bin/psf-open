#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [ -f "$SCRIPT_DIR/../lib/psf-lib.sh" ]; then
    # shellcheck source=../lib/psf-lib.sh
    source "$SCRIPT_DIR/../lib/psf-lib.sh"
else
    # shellcheck source=/dev/null
    source "${PSF_LIB:-$HOME/.local/lib/psf-assistant/psf-lib.sh}"
fi

usage() {
    printf 'Usage: psf-open NAME | PSF-YYYY-NNN[_NAME]\n' >&2
}

[ "$#" -eq 1 ] || { usage; exit 2; }

CASE_REF="$1"
psf_require_command hermes

RESOLVED="$(psf_resolve_case_ref "$CASE_REF")"
IFS=$'\t' read -r CANONICAL_CASE_ID CASE_DIR CASE_FOLDER_NAME <<< "$RESOLVED"
PROFILE="$(psf_profile_for_case "$CANONICAL_CASE_ID")"

if [ ! -d "$CASE_DIR" ]; then
    psf_err "case folder does not exist: $CASE_DIR"
    exit 1
fi

if ! psf_profile_exists "$PROFILE"; then
    psf_err "Hermes profile does not exist: $PROFILE"
    exit 1
fi

psf_check_docker_ready

printf 'Opening %s (%s)\n' "$CASE_FOLDER_NAME" "$CANONICAL_CASE_ID"
cd "$CASE_DIR/workspace"
exec hermes -p "$PROFILE" chat
